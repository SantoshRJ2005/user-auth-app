<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agency Registration | SharingYatra</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #ff6b4a;
            --secondary-color: #2c3e50;
            --light-gray: #f5f7fa;
            --dark-gray: #333;
            --white: #ffffff;
            --border-color: #dfe6f0;
            --success: #28a745;
            --danger: #dc3545;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Poppins', sans-serif; background-color: var(--light-gray); display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; }
        .container { display: flex; background-color: var(--white); border-radius: 15px; box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1); max-width: 1200px; width: 100%; min-height: 80vh; overflow: hidden; }
        .image-side { width: 45%; background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('https://images.unsplash.com/photo-1516939884455-1445c8651f81?q=80&w=1887'); background-size: cover; background-position: center; color: var(--white); display: flex; flex-direction: column; justify-content: center; padding: 50px; text-align: left; }
        .image-side .logo { font-size: 2.5rem; font-weight: 700; color: var(--primary-color); margin-bottom: 20px; }
        .image-side h1 { font-size: 2.5rem; line-height: 1.3; margin-bottom: 20px; }
        .image-side p { font-size: 1.1rem; opacity: 0.9; max-width: 400px; }
        .form-side { width: 55%; padding: 40px 50px; overflow-y: auto; }
        .form-side h2 { color: var(--secondary-color); font-size: 2rem; margin-bottom: 10px; }
        .form-side .subtitle { color: var(--dark-gray); margin-bottom: 30px; }
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .form-group { position: relative; }
        .full-width { grid-column: 1 / -1; }
        .form-group label { display: block; color: var(--secondary-color); font-weight: 500; margin-bottom: 8px; }
        .input-wrapper { position: relative; }
        .input-wrapper i { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #aaa; transition: color 0.3s; }
        .form-group input, .form-group select { width: 100%; padding: 12px 15px 12px 45px; border: 1px solid var(--border-color); border-radius: 8px; font-size: 1rem; color: var(--dark-gray); background-color: var(--light-gray); transition: border-color 0.3s, box-shadow 0.3s; }
        .form-group input:focus, .form-group select:focus { outline: none; border-color: var(--primary-color); box-shadow: 0 0 0 3px rgba(255, 107, 74, 0.2); background-color: var(--white); }
        .form-group input:focus ~ i, .form-group select:focus ~ i { color: var(--primary-color); }
        .file-upload-wrapper { border: 2px dashed var(--border-color); border-radius: 8px; padding: 30px 20px; text-align: center; cursor: pointer; transition: border-color 0.3s, background-color 0.3s; }
        .file-upload-wrapper:hover { border-color: var(--primary-color); background-color: #fff8f6; }
        .file-upload-wrapper input[type="file"] { display: none; }
        .file-upload-wrapper i { font-size: 2rem; color: var(--primary-color); margin-bottom: 10px; }
        #file-name { display: block; margin-top: 10px; color: var(--success); font-weight: 500; font-size: 0.9rem; }
        .password-wrapper .fa-eye, .password-wrapper .fa-eye-slash { cursor: pointer; right: 15px; left: auto; }
        .submit-btn { width: 100%; padding: 15px; border: none; border-radius: 8px; background: linear-gradient(90deg, #ff6b4a, #ff8a6b); color: var(--white); font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: transform 0.2s, box-shadow 0.3s; margin-top: 10px; }
        .submit-btn:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(255, 107, 74, 0.4); }
        .submit-btn:disabled { background: #ccc; cursor: not-allowed; }
        .login-link { text-align: center; margin-top: 20px; color: var(--dark-gray); }
        .login-link a { color: var(--primary-color); text-decoration: none; font-weight: 600; }
        .message { padding: 15px; border-radius: 8px; margin-bottom: 20px; }
        .message-success { color: #155724; background-color: #d4edda; border: 1px solid #c3e6cb; }
        .message-error { color: #721c24; background-color: #f8d7da; border: 1px solid #f5c6cb; }
        @media (max-width: 992px) { .container { flex-direction: column; min-height: auto; } .image-side { width: 100%; min-height: 300px; text-align: center; } .image-side p { max-width: 100%; } .form-side { width: 100%; } }
        @media (max-width: 768px) { .form-grid { grid-template-columns: 1fr; } .form-side { padding: 30px; } }
    </style>
</head>
<body>
    <div class="container">
        <div class="image-side">
            <div class="logo">SharingYatra</div>
            <h1>Elevate Your Agency. Reach New Horizons.</h1>
            <p>Join our exclusive network of travel professionals and gain access to more customers, better tools, and unparalleled growth.</p>
        </div>
        <div class="form-side">
            <h2>Create Your Partner Account</h2>
            <p class="subtitle">Fill in your agency details to get started.</p>
            <div id="messageArea"></div>
            <form id="agency-signup-form" enctype="multipart/form-data">
                <div class="form-grid">
                    <div class="form-group"><label for="agency-name">Name of Agency</label><div class="input-wrapper"><input type="text" id="agency-name" name="agencyName" placeholder="Happy Travels Pvt. Ltd." required><i class="fa-solid fa-briefcase"></i></div></div>
                    <div class="form-group"><label for="owner-name">Owner's Name</label><div class="input-wrapper"><input type="text" id="owner-name" name="ownerName" placeholder="Full name of owner" required><i class="fa-solid fa-user-tie"></i></div></div>
                    <div class="form-group"><label for="oprate-station">Operating Station</label><div class="input-wrapper"><select id="oprate-station" name="oprateStation" required><option value="" disabled selected>Select primary city</option><option value="diva">Diva</option><option value="thane">Thane</option><option value="mumbai">Mumbai</option></select><i class="fa-solid fa-map-marker-alt"></i></div></div>
                    <div class="form-group"><label for="agency-mobile">Agency Mobile</label><div class="input-wrapper"><input type="tel" id="agency-mobile" name="agencyMobile" placeholder="10-digit mobile number" required><i class="fa-solid fa-phone"></i></div></div>
                    <div class="form-group full-width"><label for="agency-email">Agency Email ID</label><div class="input-wrapper"><input type="email" id="agency-email" name="agencyEmail" placeholder="you@example.com" required><i class="fa-solid fa-envelope"></i></div></div>
                    <div class="form-group"><label for="gst-number">GST Number</label><div class="input-wrapper"><input type="text" id="gst-number" name="gstNumber" placeholder="Your agency's GSTIN" required><i class="fa-solid fa-file-invoice-dollar"></i></div></div>
                    <div class="form-group"><label for="pan-number">PAN Number</label><div class="input-wrapper"><input type="text" id="pan-number" name="panNumber" placeholder="Business PAN" required><i class="fa-solid fa-address-card"></i></div></div>
                    <div class="form-group full-width"><label for="agency-license">Agency License No.</label><div class="input-wrapper"><input type="text" id="agency-license" name="agencyLicense" placeholder="Official license number" required><i class="fa-solid fa-id-card"></i></div></div>
                    <div class="form-group full-width"><label>Upload Gumasta License</label><label for="certificate-upload" class="file-upload-wrapper"><i class="fa-solid fa-cloud-arrow-up"></i><span>Click to browse or drag & drop</span><input type="file" id="certificate-upload" name="gumastaLicense" accept=".pdf,.jpg,.jpeg,.png"></label><span id="file-name"></span></div>
                    <div class="form-group full-width"><label for="password">Set Password</label><div class="input-wrapper password-wrapper"><input type="password" id="password" name="password" placeholder="Minimum 8 characters" required><i class="fa-solid fa-lock"></i><i class="fa-solid fa-eye" id="togglePassword"></i></div></div>
                    <div class="form-group full-width"><button type="submit" id="submitButton" class="submit-btn">Create Account</button></div>
                </div>
                <p class="login-link">Already a partner? <a href="/login">Log In</a></p>
            </form>
        </div>
    </div>
<script>
    const fileInput = document.getElementById('certificate-upload');
    const fileNameDisplay = document.getElementById('file-name');
    fileInput.addEventListener('change', function() { fileNameDisplay.textContent = this.files.length > 0 ? `Selected: ${this.files[0].name}` : ''; });
    const togglePassword = document.getElementById('togglePassword');
    const passwordInput = document.getElementById('password');
    togglePassword.addEventListener('click', function() { const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password'; passwordInput.setAttribute('type', type); this.classList.toggle('fa-eye'); this.classList.toggle('fa-eye-slash'); });
    
    const signupForm = document.getElementById('agency-signup-form');
    const messageArea = document.getElementById('messageArea');
    const submitButton = document.getElementById('submitButton');
    signupForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        submitButton.disabled = true;
        submitButton.textContent = 'Registering...';
        messageArea.innerHTML = '';
        const formData = new FormData(this);
        try {
            const response = await fetch('/register-agency', { method: 'POST', body: formData });
            const result = await response.json();
            if (response.ok) {
                messageArea.innerHTML = `<div class="message message-success">${result.message}</div>`;
                signupForm.reset();
                fileNameDisplay.textContent = '';
            } else {
                messageArea.innerHTML = `<div class="message message-error">${result.message}</div>`;
            }
        } catch (error) {
            console.error('Submission Error:', error);
            messageArea.innerHTML = `<div class="message message-error">A network error occurred. Please try again.</div>`;
        } finally {
            submitButton.disabled = false;
            submitButton.textContent = 'Create Account';
        }
    });
</script>
</body>
</html>
